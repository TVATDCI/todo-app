# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB connection string
# Local:  mongodb://localhost:27017/todo-app
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/todo-app
MONGO_URI=mongodb://localhost:27017/todo-app

# Allowed CORS origin (set to your frontend URL)
CLIENT_ORIGIN=http://localhost:5173

# Note: the seed script (npm run seed) uses MONGO_URI from this file.
# Only run it against a development database — it drops all existing data.
