# Base URL for the Express API server used by the axios client.
#
# Option A (direct — current default):
#   Set to the server's full URL. Axios sends requests directly; CORS must allow
#   the client origin. Works in both dev and production.
#   VITE_API_URL=http://localhost:5001
#
# Option B (Vite proxy in dev):
#   Leave empty so axios uses relative paths (/api/…) and the Vite dev-server
#   proxy (configured in vite.config.js) forwards them to the Express server.
#   CORS is not required for same-origin proxy requests.
#   VITE_API_URL=
#
VITE_API_URL=http://localhost:5001
